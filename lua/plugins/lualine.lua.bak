vim.pack.add {
  'https://github.com/nvim-tree/nvim-web-devicons',
  'https://github.com/nvim-lualine/lualine.nvim',
  'https://github.com/linrongbin16/lsp-progress.nvim',
}

vim.api.nvim_create_autocmd({ 'BufReadPre', 'BufNewFile' }, {
  group = vim.api.nvim_create_augroup('SetupLualine', { clear = true }),
  once = true,
  callback = function()
    require('lualine').setup {
      options = {
        component_separators = { left = '', right = '' },
      },
      sections = {
        lualine_a = { 'mode' },
        lualine_b = {
          {
            'branch',
            icon = '󰘬',
            fmt = function(str)
              return str:sub(1, 12)
            end,
          },
          {
            'diff',
            colored = true,
          },
          'diagnostics',
        },
        lualine_c = {
          {
            'filename',
            path = 1,
            shorting_target = 40,
            symbols = {
              modified = ' ',
              readonly = '',
              unnamed = '',
            },
          },
        },

        lualine_x = {
          {
            'encoding',
            fmt = function(str)
              return str:upper():gsub('UTF%-8', 'UTF8')
            end,
          },
          'fileformat',
        },
        lualine_y = { 'filetype', 'progress' },
        lualine_z = { 'location' },
      },
    }
  end,
})

{
  "std::cout": {
    "prefix": "std::cout",
    "body": ["std::cout << ${0} << '\\n';"],
    "description": "Scan some messages"
  },
  "#ifndef": {
    "prefix": "#ifndef",
    "body": ["#ifndef ${1}", "#define ${1}", "#endif // ${1}"],
    "description": "Protect this header file"
  },
  "main with argc": {
    "prefix": "main",
    "body": ["int main(int argc, char* argv[]) {", "${0}", "}"],
    "description": "Generate standard C++ main function(with argc)"
  },
  "main": {
    "prefix": "main",
    "body": ["int main() {", "${0}", "}"],
    "description": "Generate standard C++ main function"
  }
}
